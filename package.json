{
  "name": "auth0-ia",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "lint": "pnpm -C apps/web lint",
    "typecheck": "pnpm -C apps/web typecheck",
    "build:index": "pnpm -C packages/indexer build && node scripts/build-index.mjs && node scripts/sync-index.mjs",
    "index": "pnpm build:index",
    "sync:index": "node scripts/sync-index.mjs",
    "drift:report": "node scripts/drift-report.mjs",
    "fetch:feedback": "node --env-file=.env.local scripts/fetch-feedback.mjs"
  }
}
