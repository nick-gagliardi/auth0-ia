# Auth0-IA Environment Configuration
# Copy this file to .env.local and fill in values

# =============================================================================
# REQUIRED: Path to your local docs-v2 clone
# =============================================================================
MAINTENANCE_DOCS_REPO_PATH=/path/to/your/docs-v2

# =============================================================================
# GIT/PR CONFIGURATION
# =============================================================================
# Target repository for maintenance PRs
MAINTENANCE_UPSTREAM_REPO=auth0/docs-v2

# Base branch to create PRs against
MAINTENANCE_BASE_BRANCH=main

# Your GitHub username (for fork-based PR workflows)
MAINTENANCE_FORK_OWNER=your-github-username

# =============================================================================
# PLAYWRIGHT/BROWSER CONFIGURATION
# =============================================================================
# Path to Chrome/Chromium (optional - auto-detected on most systems)
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome or /usr/bin/chromium-browser
MAINTENANCE_CHROME_PATH=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable maintenance mode features (audit, PR creation, etc.)
MAINTENANCE_MODE=true

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================
# GitHub OAuth for user authentication
# Create an OAuth app at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (for local dev)
# Callback URL: https://your-domain.vercel.app/api/auth/callback/github (for production)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# NextAuth.js configuration
# For local dev:
NEXTAUTH_URL=http://localhost:3000
# For production, set this to your deployed URL:
# NEXTAUTH_URL=https://your-domain.vercel.app

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here

# =============================================================================
# ENCRYPTION (REQUIRED)
# =============================================================================
# Master encryption key for storing user credentials (GitHub tokens, Anthropic keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=your_64_character_hex_string_here

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# For local development (SQLite):
DATABASE_URL=file:./dev.db

# For production (Vercel PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:port/database

# =============================================================================
# PER-USER CREDENTIALS
# =============================================================================
# Users configure their own API keys via the settings page:
# - GitHub access tokens: Obtained via OAuth (stored encrypted)
# - Anthropic API keys: Users enter their own keys (stored encrypted)
#
# Each user's credentials are used for:
# - GitHub token: PR creation, git operations
# - Anthropic key: AI-powered audit suggestions

# =============================================================================
# GLOBAL CREDENTIALS (OPTIONAL - TRANSITION PERIOD)
# =============================================================================
# These global credentials serve as fallback during the 30-day transition period
# After users have configured their own keys, remove these fallback credentials

# Global Anthropic API key (fallback)
# Users can configure their own keys in Settings
ANTHROPIC_API_KEY=

# Anthropic API base URL (optional - for custom proxies like Okta)
# Default: https://api.anthropic.com
# For Okta proxy: https://llm.atko.ai
ANTHROPIC_BASE_URL=
# Client-side version (needed for browser calls that bypass Vercel IP restrictions)
NEXT_PUBLIC_ANTHROPIC_BASE_URL=

# Anthropic model to use (optional)
# Default: claude-4-5-sonnet
ANTHROPIC_MODEL=
# Client-side version (needed for browser calls)
NEXT_PUBLIC_ANTHROPIC_MODEL=

# Global GitHub token for maintenance operations (fallback)
# Users authenticate via OAuth and use their own tokens
# Generate a token with 'repo' scope at: https://github.com/settings/tokens
MAINTENANCE_GH_TOKEN=
